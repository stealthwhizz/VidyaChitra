# ── Gemini / Google AI ──────────────────────────────────────────────────────
# Required: Get from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ── Google Cloud Storage (optional — falls back to local /static) ────────────
# Your GCS project ID
GOOGLE_CLOUD_PROJECT=
# Your GCS bucket name (must be publicly readable or use signed URLs)
GOOGLE_CLOUD_BUCKET=

# ── Sarvam AI (Indian language TTS) ─────────────────────────────────────────
# Required for Indian language audio: https://sarvam.ai
SARVAM_API_KEY=

# ── Backend URL (used for local static file serving) ─────────────────────────
BACKEND_URL=http://localhost:8080
